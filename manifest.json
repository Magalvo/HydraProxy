{
  "manifest_version": 3,
  "name": "HydraProxy",
  "version": "1.1",
  "description": "Multi-headed proxy switcher with smart per-domain routing.",
  "permissions": [
    "proxy",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/HydraProxyMini.png",
    "32": "icons/HydraProxyMini.png",
    "48": "icons/HydraProxyMini.png",
    "128": "icons/HydraProxyBG.png"
  }
}
